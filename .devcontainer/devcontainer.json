{
	"name": "pgpageshell",
	"build": {
		"context": ".",
		"dockerfile": "Dockerfile"
	},
	"features": {
		"ghcr.io/devcontainers/features/go:1": {
			"version": "1.22"
		},
		"ghcr.io/devcontainers/features/node:1": {
			"version": "20",
			"installYarnUsingApt": false
		}
	},
	"postCreateCommand": "corepack enable && cd web && pnpm install"
}
